{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/rank-check",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/subscriptions",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/purge",
      "schedule": "0 2 * * 0"
    }
  ]
}
