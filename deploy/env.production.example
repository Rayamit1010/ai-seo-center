# Copy this file to .env.production on your Linux server and replace every placeholder.
# Recommended production domain for this project:
# NEXTAUTH_URL="https://seoagent.techgeekstudio.com"

DATABASE_URL="postgresql://postgres:replace-me@127.0.0.1:5432/seo_command_center"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://seoagent.techgeekstudio.com"
NEXT_PUBLIC_APP_URL="https://seoagent.techgeekstudio.com"

ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
XAI_API_KEY=""
GROQ_API_KEY=""

RESEND_API_KEY=""
RESEND_FROM_EMAIL="SEO Reports <no-reply@techgeekstudio.com>"
REPORTS_FROM_EMAIL="SEO Reports <no-reply@techgeekstudio.com>"

GOOGLE_SERVICE_ACCOUNT_JSON=""

RATE_LIMIT_PROVIDER="memory"
JOB_QUEUE_PROVIDER="database"
JOB_QUEUE_REMOTE_ONLY="true"
JOB_QUEUE_REDIS_KEY="seo-command-center:jobs"
JOB_WORKER_POLL_INTERVAL_MS="15000"
JOB_DRAIN_BATCH_SIZE="10"

UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

SLOW_API_THRESHOLD_MS="1500"
CRON_SECRET="replace-with-openssl-rand-base64-32"
PORT="3000"
