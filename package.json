{
  "name": "seo-command-center",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:browser": "playwright test",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:sync:postgres-schema": "node scripts/sync-postgres-schema.mjs",
    "db:push:postgres": "pnpm db:sync:postgres-schema && prisma db push --schema prisma/schema.postgres.prisma",
    "db:generate:postgres": "pnpm db:sync:postgres-schema && prisma generate --schema prisma/schema.postgres.prisma",
    "jobs:drain": "tsx scripts/drain-jobs.ts",
    "jobs:daemon": "tsx scripts/run-job-worker.ts",
    "review:export": "tsx scripts/generate-engineering-review.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@paypal/paypal-js": "^9.7.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@stripe/stripe-js": "^9.4.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "google-auth-library": "^10.5.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.441.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^9.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "resend": "^4.8.0",
    "sonner": "^1.7.4",
    "stripe": "^22.1.0",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "docx": "^9.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pptxgenjs": "^4.0.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
